---
import { projects, categoryToBadgeClass } from '../data/projects';
const featured = projects.filter((p) => p.featured).slice(0, 6);
---

<section id="projects" class="py-16 md:py-20 bg-[--color-bg-alt] animate-on-scroll">
  <div class="max-w-[1100px] mx-auto px-6">
    <h2 class="text-2xl md:text-3xl font-bold text-[--color-text] mb-2">Featured Projects</h2>
    <div class="section-underline mb-8"></div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      {featured.map((project) => (
        <a href={`/projects/${project.slug}`} class="block group">
          <div class="bg-white rounded-md p-6 border border-[--color-border] shadow-md group-hover:shadow-lg transition-shadow h-full">
            <span class={`inline-block text-xs font-medium px-2.5 py-1 rounded-full mb-3 ${categoryToBadgeClass(project.category)}`}>{project.category}</span>
            <h3 class="font-semibold text-lg text-[--color-text] mb-2">{project.title}</h3>
            <p class="text-sm text-[--color-text-light] mb-2">{project.shortDescription}</p>
            {project.keyResult && <p class="text-sm font-semibold text-[--color-primary] mb-4">{project.keyResult}</p>}
            <div class="flex flex-wrap gap-2">
              {project.tags.map((tag) => (
                <span class="text-xs font-medium bg-[#dbeafe] text-[--color-primary] px-3 py-1 rounded-full">{tag}</span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>
    <div class="text-center">
      <a href="/projects" class="inline-block border-2 border-[--color-primary] text-[--color-primary] px-6 py-3 rounded-md font-medium hover:bg-[--color-primary] hover:text-white transition-colors">
        View All Projects
      </a>
    </div>
  </div>
</section>
