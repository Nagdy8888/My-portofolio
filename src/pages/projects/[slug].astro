---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { projects, categoryToBadgeClass } from '../../data/projects';
import { getTechIconUrl } from '../../data/techIcons';
import type { Project } from '../../data/projects';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const hasStructuredContent = project.problem || project.approach || project.results;
---

<Layout title={`${project.title} | Mustafa Alnagdy`} description={project.shortDescription}>
  <Navbar />
  <main class="py-16 md:py-20 bg-[var(--color-bg)]">
    <div class="max-w-[800px] mx-auto px-6">
      <a href="/projects" class="text-sm text-[var(--color-primary)] hover:underline mb-6 inline-block">&larr; Back to All Projects</a>

      <div class="flex flex-wrap gap-1.5 mb-4">
        {project.categories.map((cat) => (
          <span class={`inline-block text-xs font-medium px-2.5 py-1 rounded-full ${categoryToBadgeClass(cat)}`}>{cat}</span>
        ))}
      </div>
      <h1 class="text-3xl md:text-4xl font-bold text-[var(--color-text)] mb-4">{project.title}</h1>
      <div class="flex flex-wrap gap-2 mb-6">
        {project.tags.map((tag) => {
          const iconUrl = getTechIconUrl(tag);
          return iconUrl ? (
            <span class="tech-tag inline-flex items-center gap-1.5 text-xs font-medium px-3 py-1.5 rounded-full">
              <img src={iconUrl} alt="" width="16" height="16" class="flex-shrink-0" />
              {tag}
            </span>
          ) : (
            <span class="tag-pill text-xs font-medium px-3 py-1 rounded-full">{tag}</span>
          );
        })}
      </div>

      {project.screenshots && project.screenshots.length > 0 ? (
        <div class="screenshot-gallery mb-8" id="screenshot-gallery">
          {project.screenshots.map((src, i) => (
            <button type="button" class="screenshot-card" data-screenshot-src={src} aria-label={`View screenshot ${i + 1} full size`}>
              <img src={src} alt={`Screenshot ${i + 1}`} class="w-full h-auto object-contain" />
            </button>
          ))}
        </div>
      ) : project.image ? (
        <div class="mb-8 rounded-md overflow-hidden border border-[var(--color-border)] shadow-md">
          <img src={project.image} alt={`${project.title} - project visual`} class="w-full h-auto object-cover" />
        </div>
      ) : null}

      <div id="screenshot-lightbox" class="screenshot-lightbox" role="dialog" aria-modal="true" aria-label="Screenshot full size" hidden>
        <button type="button" class="screenshot-lightbox-backdrop" aria-label="Close"></button>
        <div class="screenshot-lightbox-content">
          <img id="screenshot-lightbox-img" src="" alt="Screenshot full size" />
          <button type="button" class="screenshot-lightbox-close" aria-label="Close">&times;</button>
        </div>
      </div>

      <script>
        const gallery = document.getElementById('screenshot-gallery');
        const lightbox = document.getElementById('screenshot-lightbox');
        const lightboxImg = document.getElementById('screenshot-lightbox-img');
        const backdrop = lightbox?.querySelector('.screenshot-lightbox-backdrop');
        const closeBtn = lightbox?.querySelector('.screenshot-lightbox-close');

        function openLightbox(src: string) {
          if (!lightbox || !lightboxImg) return;
          lightboxImg.setAttribute('src', src);
          lightbox.removeAttribute('hidden');
          document.body.style.overflow = 'hidden';
        }

        function closeLightbox() {
          if (!lightbox) return;
          lightbox.setAttribute('hidden', '');
          document.body.style.overflow = '';
        }

        gallery?.querySelectorAll('.screenshot-card[data-screenshot-src]').forEach((card) => {
          card.addEventListener('click', () => {
            const src = card.getAttribute('data-screenshot-src');
            if (src) openLightbox(src);
          });
        });

        backdrop?.addEventListener('click', closeLightbox);
        closeBtn?.addEventListener('click', closeLightbox);

        lightbox?.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') closeLightbox();
        });
      </script>

      {hasStructuredContent ? (
        <div class="space-y-8 mb-8">
          {project.problem && (
            <section>
              <h2 class="text-xl font-semibold text-[var(--color-text)] mb-2">The Problem</h2>
              <p class="text-base leading-relaxed text-[var(--color-text-light)]">{project.problem}</p>
            </section>
          )}
          {project.approach && (
            <section>
              <h2 class="text-xl font-semibold text-[var(--color-text)] mb-2">Approach</h2>
              <p class="text-base leading-relaxed text-[var(--color-text-light)]">{project.approach}</p>
            </section>
          )}
          {project.results && (
            <section>
              <h2 class="text-xl font-semibold text-[var(--color-text)] mb-2">Results</h2>
              <p class="text-base leading-relaxed text-[var(--color-text-light)]">{project.results}</p>
              {project.keyResult && <p class="mt-3 text-base font-semibold text-[var(--color-primary)]">{project.keyResult}</p>}
            </section>
          )}
        </div>
      ) : (
        <div class="mb-8">
          <p class="text-base leading-relaxed text-[var(--color-text-light)]">{project.fullDescription}</p>
          {project.keyResult && <p class="mt-4 text-base font-semibold text-[var(--color-primary)]">{project.keyResult}</p>}
        </div>
      )}

      {project.tools && project.tools.length > 0 && (
        <section class="mb-8">
          <h2 class="text-xl font-semibold text-[var(--color-text)] mb-3">Tools Used</h2>
          <div class="flex flex-wrap gap-2">
            {project.tools.map((tool) => (
              <span class="text-sm bg-[var(--color-bg-alt)] text-[var(--color-text-light)] px-3 py-1.5 rounded-md border border-[var(--color-border)]">{tool}</span>
            ))}
          </div>
        </section>
      )}

      <div class="flex flex-wrap gap-4">
        {project.github ? (
          <a href={project.github} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-[var(--color-primary)] text-white px-5 py-2.5 rounded-md font-medium hover:bg-[var(--color-primary-hover)] transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            <span>View on GitHub</span>
          </a>
        ) : (
          <span class="inline-flex items-center gap-2 bg-[var(--color-border)] text-[var(--color-text-light)] px-5 py-2.5 rounded-md font-medium cursor-default">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            <span>GitHub - Coming Soon</span>
          </span>
        )}
        {project.liveUrl && (
          <a href={project.liveUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 border-2 border-[var(--color-primary)] text-[var(--color-primary)] px-5 py-2.5 rounded-md font-medium hover:bg-[var(--color-primary)] hover:text-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
              <polyline points="15 3 21 3 21 9" />
              <line x1="10" y1="14" x2="21" y2="3" />
            </svg>
            <span>Live Demo</span>
          </a>
        )}
      </div>
    </div>
  </main>
  <Footer />
</Layout>
